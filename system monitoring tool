import subprocess

def run_command(command):
    try:
        result = subprocess.run(command, capture_output=True, text=True, shell=True)
        return result.stdout if result.stdout else "Keine Ausgabe erhalten."
    except Exception as e:
        return f"Fehler: {e}"

def show_ip_config():
    print("\n=== IP CONFIGURATION ===")
    print(run_command("ipconfig"))

def show_arp_table():
    print("\n=== NETWORK DEVICES (ARP TABLE) ===")
    print(run_command("arp -a"))

def ping_test():
    print("\n=== INTERNET CONNECTION TEST ===")
    print(run_command("ping 8.8.8.8 -n 4"))

def menu():
    while True:
        print("\n=== NETWORK ANALYSIS TOOL ===")
        print("1 - Show IP Configuration")
        print("2 - Show Network Devices")
        print("3 - Test Internet Connection")
        print("4 - Exit")

        try:
            choice = input("Select option: ").strip()
        except OSError:
            print("\n⚠️ Eingabe nicht möglich – automatische Demo wird ausgeführt...\n")
            demo_mode()
            break

        if choice == "1":
            show_ip_config()
        elif choice == "2":
            show_arp_table()
        elif choice == "3":
            ping_test()
        elif choice == "4":
            print("Exiting...")
            break
        else:
            print("Invalid input! Please choose 1-4.")

def demo_mode():
    print("=== DEMO MODE ===")
    show_ip_config()
    show_arp_table()
    ping_test()

if __name__ == "__main__":
    menu()
