from __future__ import annotations

import ctypes
import logging
import os
import platform
import shutil
import socket
import subprocess
import time
from datetime import datetime
from pathlib import Path
from typing import Optional


BASE_DIR = Path(__file__).resolve().parent
LOG_DIR = BASE_DIR / "logs"
REPORT_DIR = BASE_DIR / "reports"
APP_LOG_FILE = LOG_DIR / "admin_tool.log"
DEFAULT_PING_TARGET = "8.8.8.8"


def setup_logging() -> None:
    """Create log directories and configure application logging."""
    LOG_DIR.mkdir(exist_ok=True)
    REPORT_DIR.mkdir(exist_ok=True)

    logging.basicConfig(
        filename=APP_LOG_FILE,
        level=logging.INFO,
        format="%(asctime)s | %(levelname)s | %(message)s",
        encoding="utf-8",
    )


def print_header(title: str) -> None:
    """Display a consistent section header."""
    line = "=" * 70
    print(f"\n{line}\n{title}\n{line}")


def wait_for_enter() -> None:
    """Pause so the user can read the output comfortably."""
    input("\nPress Enter to return to the menu...")


def run_command(command: list[str], timeout: int = 10) -> str:
    """Run a system command safely without shell expansion."""
    try:
        result = subprocess.run(
            command,
            capture_output=True,
            text=True,
            timeout=timeout,
            check=False,
            shell=False,
            encoding="utf-8",
            errors="replace",
        )

        if result.returncode != 0:
            stderr = result.stderr.strip() or "No additional error details available."
            return f"Command returned exit code {result.returncode}.\n{stderr}"

        return result.stdout.strip() or "No output available."
    except FileNotFoundError:
        return "Required system command was not found on this device."
    except subprocess.TimeoutExpired:
        return "The command timed out before it finished."
    except OSError as error:
        return f"Operating system error: {error}"


def format_bytes(size_in_bytes: int) -> str:
    """Convert bytes into a human-readable unit."""
    size = float(size_in_bytes)
    for unit in ["B", "KB", "MB", "GB", "TB"]:
        if size < 1024 or unit == "TB":
            return f"{size:.2f} {unit}"
        size /= 1024
    return f"{size_in_bytes} B"


def get_cpu_usage() -> str:
    """Return CPU usage with a platform-aware fallback."""
    if platform.system().lower() == "windows":
        class FileTime(ctypes.Structure):
            _fields_ = [("dwLowDateTime", ctypes.c_ulong), ("dwHighDateTime", ctypes.c_ulong)]

        def to_int(file_time: FileTime) -> int:
            return (file_time.dwHighDateTime << 32) + file_time.dwLowDateTime

        idle_time_1 = FileTime()
        kernel_time_1 = FileTime()
        user_time_1 = FileTime()
        idle_time_2 = FileTime()
        kernel_time_2 = FileTime()
        user_time_2 = FileTime()

        try:
            ctypes.windll.kernel32.GetSystemTimes(
                ctypes.byref(idle_time_1),
                ctypes.byref(kernel_time_1),
                ctypes.byref(user_time_1),
            )
            time.sleep(0.5)
            ctypes.windll.kernel32.GetSystemTimes(
                ctypes.byref(idle_time_2),
                ctypes.byref(kernel_time_2),
                ctypes.byref(user_time_2),
            )

            idle_delta = to_int(idle_time_2) - to_int(idle_time_1)
            kernel_delta = to_int(kernel_time_2) - to_int(kernel_time_1)
            user_delta = to_int(user_time_2) - to_int(user_time_1)
            total_delta = kernel_delta + user_delta

            if total_delta <= 0:
                return "Unknown"

            usage = (1 - (idle_delta / total_delta)) * 100
            return f"{usage:.1f}"
        except (AttributeError, OSError):
            return "Unknown"

    try:
        load_average = os.getloadavg()[0]
        cpu_count = os.cpu_count() or 1
        return f"{(load_average / cpu_count) * 100:.1f}"
    except (AttributeError, OSError):
        return "Unknown"


def get_memory_info() -> tuple[str, str]:
    """Return total and used RAM values in a human-readable format."""
    if platform.system().lower() == "windows":
        try:
            class MemoryStatusEx(ctypes.Structure):
                _fields_ = [
                    ("dwLength", ctypes.c_ulong),
                    ("dwMemoryLoad", ctypes.c_ulong),
                    ("ullTotalPhys", ctypes.c_ulonglong),
                    ("ullAvailPhys", ctypes.c_ulonglong),
                    ("ullTotalPageFile", ctypes.c_ulonglong),
                    ("ullAvailPageFile", ctypes.c_ulonglong),
                    ("ullTotalVirtual", ctypes.c_ulonglong),
                    ("ullAvailVirtual", ctypes.c_ulonglong),
                    ("sullAvailExtendedVirtual", ctypes.c_ulonglong),
                ]

            memory_status = MemoryStatusEx()
            memory_status.dwLength = ctypes.sizeof(MemoryStatusEx)
            ctypes.windll.kernel32.GlobalMemoryStatusEx(ctypes.byref(memory_status))

            total_bytes = memory_status.ullTotalPhys
            used_bytes = total_bytes - memory_status.ullAvailPhys
            return format_bytes(total_bytes), format_bytes(used_bytes)
        except (AttributeError, OSError):
            return "Unknown", "Unknown"

    try:
        page_size = os.sysconf("SC_PAGE_SIZE")
        total_pages = os.sysconf("SC_PHYS_PAGES")
        available_pages = os.sysconf("SC_AVPHYS_PAGES")
        total_bytes = page_size * total_pages
        used_bytes = total_bytes - (page_size * available_pages)
        return format_bytes(total_bytes), format_bytes(used_bytes)
    except (AttributeError, OSError, ValueError):
        return "Unknown", "Unknown"


def get_processor_name() -> str:
    """Return the processor name in a platform-aware way."""
    if platform.system().lower() == "windows":
        return os.environ.get("PROCESSOR_IDENTIFIER", "Unknown")

    return platform.processor() or "Unknown"


def get_system_info() -> str:
    """Collect basic hardware and operating system information."""
    try:
        cpu_usage = get_cpu_usage()
        ram_total, ram_used = get_memory_info()
        disk = shutil.disk_usage(BASE_DIR.anchor or "/")

        lines = [
            f"Computer Name   : {socket.gethostname()}",
            f"Operating System: {platform.system()} {platform.release()}",
            f"Processor       : {get_processor_name()}",
            f"CPU Usage       : {cpu_usage} %",
            f"RAM Total       : {ram_total}",
            f"RAM Used        : {ram_used}",
            f"Disk Total      : {format_bytes(disk.total)}",
            f"Disk Used       : {format_bytes(disk.used)} ({(disk.used / disk.total) * 100:.1f} %)",
            f"Disk Free       : {format_bytes(disk.free)}",
        ]
        logging.info("System information was collected successfully.")
        return "\n".join(lines)
    except Exception as error:  # pragma: no cover - defensive stability for runtime issues
        logging.exception("Failed to collect system information.")
        return f"An error occurred while collecting system information: {error}"


def get_network_commands() -> tuple[list[str], list[str]]:
    """Choose commands based on the current operating system."""
    if platform.system().lower() == "windows":
        return ["ipconfig", "/all"], ["arp", "-a"]
    return ["ip", "addr"], ["arp", "-a"]


def get_network_info() -> str:
    """Collect IP configuration and ARP table details."""
    try:
        ipconfig_command, arp_command = get_network_commands()
        ip_configuration = run_command(ipconfig_command)
        arp_table = run_command(arp_command)

        result = [
            "IP Configuration",
            "-" * 70,
            ip_configuration,
            "",
            "ARP Table",
            "-" * 70,
            arp_table,
        ]
        logging.info("Network information was collected successfully.")
        return "\n".join(result)
    except Exception as error:  # pragma: no cover - defensive stability for runtime issues
        logging.exception("Failed to collect network information.")
        return f"An error occurred while collecting network information: {error}"


def is_valid_ping_target(target: str) -> bool:
    """Validate the target to avoid unsafe or malformed input."""
    if not target or len(target) > 253:
        return False

    allowed_characters = set("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.-")
    return all(character in allowed_characters for character in target)


def test_internet_connection(target: str) -> str:
    """Ping a host safely and return the output."""
    if not is_valid_ping_target(target):
        return (
            "Invalid target. Please use a hostname or IP address containing only "
            "letters, numbers, dots, or hyphens."
        )

    ping_count_flag = "-n" if platform.system().lower() == "windows" else "-c"
    command = ["ping", ping_count_flag, "4", target]
    ping_output = run_command(command, timeout=15)

    logging.info("Ping test executed for target: %s", target)
    return ping_output


def save_report(report_title: str, report_content: str) -> Optional[Path]:
    """Save the current output to a timestamped text file."""
    if not report_content.strip():
        return None

    timestamp = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
    safe_title = report_title.lower().replace(" ", "_")
    report_file = REPORT_DIR / f"{timestamp}_{safe_title}.txt"

    try:
        report_file.write_text(report_content, encoding="utf-8")
        logging.info("Report saved to file: %s", report_file)
        return report_file
    except OSError:
        logging.exception("Failed to save report file.")
        return None


def show_menu() -> None:
    """Print the main menu."""
    print_header("IT Admin Tool")
    print("1. Show system information")
    print("2. Run network analysis")
    print("3. Test internet connection (ping)")
    print("4. Save last result to file")
    print("5. Show log file location")
    print("0. Exit")


def handle_choice(choice: str, last_title: str, last_result: str) -> tuple[str, str, bool]:
    """Handle menu actions and return updated state."""
    should_exit = False

    if choice == "1":
        title = "System Information"
        result = get_system_info()
        print_header(title)
        print(result)
        return title, result, should_exit

    if choice == "2":
        title = "Network Analysis"
        result = get_network_info()
        print_header(title)
        print(result)
        return title, result, should_exit

    if choice == "3":
        user_input = input(f"Enter a host or IP address [{DEFAULT_PING_TARGET}]: ").strip()
        target = user_input or DEFAULT_PING_TARGET
        title = f"Ping Test - {target}"
        result = test_internet_connection(target)
        print_header(title)
        print(result)
        return title, result, should_exit

    if choice == "4":
        print_header("Save Report")
        report_path = save_report(last_title or "report", last_result)
        if report_path is None:
            print("No result is available yet. Run a tool first, then save the output.")
        else:
            print(f"Report saved successfully:\n{report_path}")
        return last_title, last_result, should_exit

    if choice == "5":
        print_header("Log File")
        print(f"Application log file:\n{APP_LOG_FILE}")
        logging.info("Log file path was displayed to the user.")
        return last_title, last_result, should_exit

    if choice == "0":
        logging.info("Application closed by user.")
        print("\nThank you for using IT Admin Tool.")
        should_exit = True
        return last_title, last_result, should_exit

    print_header("Invalid Selection")
    print("Please choose one of the available menu options.")
    logging.warning("User entered an invalid menu option: %s", choice)
    return last_title, last_result, should_exit


def main() -> None:
    """Start the terminal-based administration tool."""
    setup_logging()
    logging.info("Application started.")

    last_title = ""
    last_result = ""

    while True:
        try:
            show_menu()
            choice = input("\nSelect an option: ").strip()
            last_title, last_result, should_exit = handle_choice(choice, last_title, last_result)

            if should_exit:
                break

            wait_for_enter()
        except KeyboardInterrupt:
            print("\n\nProgram interrupted by user. Exiting gracefully.")
            logging.warning("Application interrupted by keyboard input.")
            break
        except Exception as error:  # pragma: no cover - last safety net for a terminal tool
            print("\nAn unexpected error occurred, but the program is still stable.")
            print(f"Details: {error}")
            logging.exception("Unexpected application error.")
            wait_for_enter()


if __name__ == "__main__":
    main()

